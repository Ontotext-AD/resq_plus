[PrefixDeclaration]
ex:         http://example.org/
owl:        http://www.w3.org/2002/07/owl#
rdf:        http://www.w3.org/1999/02/22-rdf-syntax-ns#
xml:        http://www.w3.org/XML/1998/namespace
xsd:        http://www.w3.org/2001/XMLSchema#
foaf:       http://xmlns.com/foaf/0.1/
obda:       https://w3id.org/obda/vocabulary#
rdfs:       http://www.w3.org/2000/01/rdf-schema#
sct:        http://snomed.info/id/
btl2:       http://purl.org/biotop/btl2.owl#
scdm:       http://www.semanticweb.org/catimc/SemanticCommonDataModel#
resq:       http://www.semanticweb.org/catimc/resqplus#
ofn:        http://www.ontotext.com/sparql/functions/
rin:        http://www.semanticweb.org/resqplus/instances#
data:       http://resqplus-resources/ontologies/resqplus-data#  


[MappingDeclaration] @collection [[

mappingId   ClinicalCaseID
target      data:Case_{case_id} a resq:ClinicalCase ; resq:caseId "{label}" .
source      SELECT si."case_id" as case_id , ss.case_id as label from "public"."strokehealthcaremodel_inpatientcase" si join "strokehealthcaremodel_casemodel" ss on si.case_id = ss.id



mappingId   ClinicalCaseAdmissionData
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasPart data:ObservationResultSt_AdmissionAge_age_{case_id} ; scdm:hasPart data:ClinicalSituationSt_AdmissionGender_sex_{case_id} ; scdm:hasPart data:ObservationResultSt_TimeOfSymptomOnset_onset_timestamp_{case_id} ; scdm:hasPart data:ObservationResultSt_TimeArrivalToHospital_hospital_timestamp_{case_id} .
source      Select "case_id" from "public"."strokehealthcaremodel_inpatientcase"


mappingId   ClinicalCaseAdmissionAgeStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasAge {age}^^xsd:integer.
source      SELECT "case_id" , "age" from strokehealthcaremodel_inpatientcase si



mappingId   ClinicalCaseArrivalDate
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:isArrivalAt {arrival_time}^^xsd:date.
source      select	case_id, date(hospital_timestamp) as arrival_time from public.strokehealthcaremodel_inpatientcase si 


mappingId   ClinicalCaseArrivalTimestamp
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:isArrivalTimestamp {hospital_timestamp}^^xsd:dateTime.
source      select	case_id, hospital_timestamp from public.strokehealthcaremodel_inpatientcase si 


mappingId   ClinicalCaseProvider
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasPart data:Provider_{provider_id} .
source      Select "case_id", "provider_id" from "public"."strokehealthcaremodel_inpatientcase"




mappingId   ClinicalCaseProviderStright
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasProvider data:Provider_{provider_id} .
source      Select "case_id", "provider_id" from "public"."strokehealthcaremodel_inpatientcase"





mappingId   ClinicalCaseAdmissionDataAdd
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasPart data:ClinicalSituationSt_AdmissionStrokeWhileAsleep_wakeup_stroke_{case_id} ; scdm:hasPart data:ClinicalSituationSt_AdmissionStrokeWhileHospitalized_inhospital_stroke_{case_id} ; scdm:hasPart data:ClinicalSituationSt_AdmissionFirstAttendedDepartment_first_contact_place_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionArrivalMode_arrival_mode_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionEMSPrenotification_ems_prenotification_{case_id} ; scdm:hasPart data:ClinicalSituationSt_AdmissionPatientHospitalizedIn_hospitalized_in_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionPatientDepartment_admission_department_{case_id}.
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase"


mappingId   ClinicalCaseAdmissionExamination
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasPart data:ObservationResultSt_AdmissionExaminationMRS_prestroke_mrs_{case_id} ; scdm:hasPart data:ObservationResultSt_AdmissionExaminationNIHSS_nihss_score_{case_id} ; scdm:hasPart data:ObservationResultSt_AdmissionExaminationGCS_gcs_score_{case_id} ; scdm:hasPart data:ClinicalSituationSt_AdmissionExaminationGCSLevel_gcs_level_{case_id} ; scdm:hasPart data:ObservationResultSt_AdmissionExaminationGlucose_glucose_{case_id} ;  scdm:hasPart data:ObservationResultSt_AdmissionExaminationBloodPressure_systolic_pressure_{case_id} ; scdm:hasPart data:ObservationResultSt_AdmissionExaminationBloodPressure_diastolic_pressure_{case_id} ; scdm:hasPart data:ObservationResultSt_AdmissionExaminationCholesterol_cholesterol_{case_id} ; scdm:hasPart data:ObservationResultSt_ASPECTScore_aspects_score_{case_id}.
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase"








mappingId   ClinicalCaseAdmissionExaminationMRSdirection
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasAdMrsValue {prestroke_mrs}^^xsd:integer.
source      SELECT "case_id", "prestroke_mrs" from "public"."strokehealthcaremodel_inpatientcase" where prestroke_mrs is not null

mappingId   ClinicalCaseAdmissionExaminationNihssdirection
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasAdNihssValue {nihss_score}^^xsd:integer.
source      SELECT "case_id" , "nihss_score" from strokehealthcaremodel_inpatientcase si where nihss_score is not null







mappingId   ClinicalCaseOcclusionFoundandLeft
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasPart data:ClinicalSituationSt_ArterialOcclusion_occlusion_found_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ArterialOcclusion_occlusion_left_mca_m1_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ArterialOcclusion_occlusion_left_mca_m2_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ArterialOcclusion_occlusion_left_mca_m3_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ArterialOcclusion_occlusion_left_aca_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ArterialOcclusion_occlusion_left_pca_p1_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ArterialOcclusion_occlusion_left_pca_p2_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ArterialOcclusion_occlusion_left_cae_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ArterialOcclusion_occlusion_left_cai_{case_id}.
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase"

mappingId   ClinicalCaseOcclusionFoundandRight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasPart data:ClinicalSituationSt_ArterialOcclusion_occlusion_right_mca_m1_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ArterialOcclusion_occlusion_right_mca_m2_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ArterialOcclusion_occlusion_right_mca_m3_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ArterialOcclusion_occlusion_right_aca_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ArterialOcclusion_occlusion_right_pca_p1_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ArterialOcclusion_occlusion_right_pca_p2_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ArterialOcclusion_occlusion_right_cae_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ArterialOcclusion_occlusion_right_cai_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ArterialOcclusion_occlusion_ba_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ArterialOcclusion_occlusion_va_{case_id}.
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase"


mappingId   ClinicalCasePerfusion
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasPart data:ClinicalSituationSt_CT_MRPerfusionDeficit_perfusion_deficit_medial_{case_id} ; scdm:hasPart data:ClinicalSituationSt_CT_MRPerfusionDeficit_perfusion_deficit_anterior_{case_id} ; scdm:hasPart data:ClinicalSituationSt_CT_MRPerfusionDeficit_perfusion_deficit_posterior_{case_id} ; scdm:hasPart data:ClinicalSituationSt_CT_MRPerfusionDeficit_perfusion_deficit_carotid_{case_id} ; scdm:hasPart data:ClinicalSituationSt_UnknownPerfusionDeficitAndBilateralStenosis_perfusion_deficit_bilateral_stenosis_{case_id} ; scdm:hasPart data:ObservationResultSt_CT_MRPerfusionDeficitCorePerfusionVolume_perfusion_core_volume_{case_id} ; scdm:hasPart data:ClinicalSituationSt_UnknownPerfusionDeficitAndBilateralStenosis_hypoperfusion_volume_{case_id} . 
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase"


mappingId   ClinicalCaseAdmissionTreatment
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasPart data:ClinicalProcedureSt_AdmissionTreatment_before_onset_antidiabetics_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionTreatment_before_onset_antihypertensives_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionTreatment_before_onset_any_anticoagulant_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionTreatment_before_onset_any_antiplatelet_{case_id} ;  scdm:hasPart data:ClinicalProcedureSt_AdmissionTreatment_before_onset_other_anticoagulant_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionTreatment_before_onset_other_antiplatelet_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionTreatment_before_onset_apixaban_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionTreatment_before_onset_asa_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionTreatment_before_onset_cilostazol_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionTreatment_before_onset_clopidogrel_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionTreatment_before_onset_dabigatran_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionTreatment_before_onset_dipyridamole_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionTreatment_before_onset_edoxaban_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionTreatment_before_onset_heparin_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionTreatment_before_onset_prasugrel_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionTreatment_before_onset_rivaroxaban_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionTreatment_before_onset_statin_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionTreatment_before_onset_ticagrelor_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionTreatment_before_onset_ticlopidine_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionTreatment_before_onset_warfarin_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AdmissionTreatment_before_onset_other_{case_id} ; scdm:hasPart data:ClinicalSituationSt_AdmissionTreatmentHormonalContraception_before_onset_contraception_{case_id} .
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase"


mappingId   ClinicalCaseAdmissionRiskFactor
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasPart data:ClinicalSituationSt_AdmissionRiskFactors_risk_hypertension_{case_id} ;   scdm:hasPart data:ClinicalSituationSt_AdmissionRiskFactors_risk_diabetes_{case_id} ;   scdm:hasPart data:ClinicalSituationSt_AdmissionRiskFactors_risk_hyperlipidemia_{case_id} ;  scdm:hasPart data:ClinicalSituationSt_AdmissionRiskFactors_risk_atrial_fibrillation_{case_id}; scdm:hasPart data:ClinicalSituationSt_AdmissionRiskFactors_risk_congestive_heart_failure_{case_id} ;   scdm:hasPart data:ClinicalSituationSt_AdmissionRiskFactors_risk_smoker_last_10_years_{case_id} ;   scdm:hasPart data:ClinicalSituationSt_AdmissionRiskFactors_risk_smoker_{case_id} ; scdm:hasPart data:ClinicalSituationSt_AdmissionRiskFactors_risk_previous_stroke_{case_id} ;    scdm:hasPart data:ClinicalSituationSt_AdmissionRiskFactors_risk_previous_ischemic_stroke_{case_id} ;   scdm:hasPart data:ClinicalSituationSt_AdmissionRiskFactors_risk_previous_hemorrhagic_stroke_{case_id} ;    scdm:hasPart data:ClinicalSituationSt_AdmissionRiskFactors_risk_coronary_artery_disease_or_myocardial_infarction_{case_id} ; scdm:hasPart data:ClinicalSituationSt_AdmissionRiskFactors_risk_hiv_{case_id} ;    scdm:hasPart data:ClinicalSituationSt_AdmissionRiskFactors_risk_covid_{case_id} ;  scdm:hasPart data:ClinicalSituationSt_AdmissionRiskFactors_risk_other_{case_id} ; scdm:hasPart data:ClinicalSituationSt_AdmissionRiskFactors_risk_vte_{case_id} ; scdm:hasPart data:ClinicalSituationSt_AdmissionRiskFactors_risk_sleep_apnea_{case_id} ; scdm:hasPart data:ClinicalSituationSt_AdmissionRiskFactors_risk_alcohol_overuse_{case_id}.
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase"







mappingId   ClinicalCaseAdmissionExaminationHypertensionStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasRisk sct:38341003.
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase" si where risk_hypertension = True

mappingId   ClinicalCaseAdmissionExaminationDiabetesStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasRisk sct:73211009.
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase" si where risk_diabetes = True

mappingId   ClinicalCaseAdmissionExaminationHyperlipidemiaStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasRisk sct:55822004.
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase" si where risk_hyperlipidemia = True

mappingId   ClinicalCaseAdmissionExaminationAtrialFibStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasRisk resq:AtrialFibrillationOrFlutter.
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase" si where risk_atrial_fibrillation = True

mappingId   ClinicalCaseAdmissionExaminationHeartFailureStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasRisk sct:42343007 .
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase" si where risk_congestive_heart_failure = True

mappingId   ClinicalCaseAdmissionExaminationSmokerStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasRisk sct:77176002.
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase" si where risk_smoker_last_10_years = True or risk_smoker = True

mappingId   ClinicalCaseAdmissionExaminationPreviousStrokeStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasRisk sct:230690007 .
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase" si where risk_previous_stroke = True


mappingId   ClinicalCaseAdmissionExaminationTIAStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasRisk resq:TIAstrokeLeadingToHospitalization .
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase" si where risk_previous_ischemic_stroke = True 


mappingId   ClinicalCaseAdmissionExaminationHemorrhagicStrStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasRisk sct:230706003 .
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase" si where risk_previous_hemorrhagic_stroke = True 

mappingId   ClinicalCaseAdmissionExaminationMyocardiaInfStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasRisk resq:PreviousMyocardialInfarction .
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase" si where risk_coronary_artery_disease_or_myocardial_infarction = True 

mappingId   ClinicalCaseAdmissionExaminationHIVStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasRisk sct:86406008 .
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase" si where risk_hiv = True 

mappingId   ClinicalCaseAdmissionExaminationCovidStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasRisk sct:840539006 .
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase" si where risk_covid = True 

mappingId   ClinicalCaseAdmissionExaminationOtherRisksStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasRisk resq:OtherRiskFactor .
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase" si where risk_other = True 

mappingId   ClinicalCaseAdmissionExaminationVTEStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasRisk sct:429098002 .
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase" si where risk_vte = True 

mappingId   ClinicalCaseAdmissionExaminationAppneaRisksStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasRisk sct:73430006 .
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase" si where risk_sleep_apnea = True 


mappingId   ClinicalCaseAdmissionExaminationAlcoholOverUseRisksStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasRisk sct:66590003 .
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase" si where risk_alcohol_overuse = True 










mappingId   ClinicalCaseDiagnosisAssessment
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasPart data:ObservationResultSt_DiagnosisImaging_imaging_timestamp_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_DiagnosisImaging_imaging_type_{case_id} ; scdm:hasPart data:ClinicalSituationSt_StrokeType_stroke_type_{case_id} .
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase"





mappingId   ClinicalCaseAdmissionExaminationIschemicStrokeStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasStrokeType sct:422504002 .
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase" si where stroke_type_id = 1 


mappingId   ClinicalCaseAdmissionExaminationCHStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasStrokeType sct:274100004 .
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase" si where stroke_type_id = 2

mappingId   ClinicalCaseAdmissionExaminationTIAstrokeStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasStrokeType sct:266257000 .
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase" si where stroke_type_id = 3

mappingId   ClinicalCaseAdmissionExaminationSAHstrokeStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasStrokeType sct:21454007 .
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase" si where stroke_type_id = 4

mappingId   ClinicalCaseAdmissionExaminationCVTstrokestrokeStraight
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasStrokeType sct:95455008 .
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase" si where stroke_type_id = 5













mappingId   ClinicalCaseOldInfarcts
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasPart data:ClinicalSituationSt_OldInfarcts_old_infarcts_any_{case_id} ; scdm:hasPart data:ClinicalSituationSt_OldInfarcts_old_infarcts_cortical_{case_id} ; scdm:hasPart data:ClinicalSituationSt_OldInfarcts_old_infarcts_subcortical_{case_id} ; scdm:hasPart data:ClinicalSituationSt_OldInfarcts_old_infarcts_brainstem_{case_id} .
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase"


mappingId   ClinicalCaseThrombolysisThrombectomy
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasPart data:ClinicalProcedureSt_ThrombolysisTreatment_thrombolysis_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_ThrombolysisTreatment_no_thrombolysis_reason_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_AnticoagulantAntidoteAdmin_ivt_antidote_given_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_ThrombolysisTreatment_ivt_drug_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_ThrombolysisTreatment_ivt_drug_dose_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_ThrombolysisTreatment_ivt_application_department_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_ThrombolysisTreatment_bolus_timestamp_{case_id} ; scdm:hasPart data:ObservationResultSt_Door2NeedleTime_door_to_needle_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_ThrombectomyTreatment_no_thrombectomy_reason_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_ThrombectomyTreatment_thrombectomy_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_ThrombectomyTreatment_puncture_timestamp_{case_id} ; scdm:hasPart  data:ObservationResultSt_Door2GroinTime_door_to_groin_{case_id} ; scdm:hasPart data:ObservationResultSt_mTICIScore_mtici_score_{case_id} ; scdm:hasPart data:ObservationResultSt_ReperfusionTimeStamp_reperfusion_timestamp_{case_id} ; scdm:hasPart data:PrimitiveValue_transfer_timestamp_{case_id}.
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase"

mappingId   ThrombectomyComplications
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasPart data:ClinicalSituationSt_ThrombectomyComplications_mt_complications_perforation_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ThrombectomyComplications_mt_complications_dissection_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ThrombectomyComplications_mt_complications_embolization_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ThrombectomyComplications_mt_complications_hematoma_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ThrombectomyComplications_mt_complications_other_{case_id} ; scdm:hasPart data:ObservationResultSt_BleedingVolume_bleeding_volume_{case_id}.
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase"


mappingId   ClinicalCaseBleeding
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasPart data:ClinicalSituationSt_InfratentorialSourceBleeding_infratentorial_hemorrhage_{case_id} ; scdm:hasPart data:ClinicalSituationSt_SourceBleedingFound_bleeding_source_found_{case_id} ; scdm:hasPart data:ClinicalSituationSt_IntraventricularSourceBleeding_intraventricular_hemorrhage_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ReasonForBleeding_bleeding_reason_hypertension_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ReasonForBleeding_bleeding_reason_aneurysm_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ReasonForBleeding_bleeding_reason_malformation_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ReasonForBleeding_bleeding_reason_anticoagulant_{case_id} ; scdm:hasPart  data:ClinicalSituationSt_ReasonForBleeding_bleeding_reason_angiopathy_{case_id} ; scdm:hasPart data:ClinicalSituationSt_ReasonForBleeding_bleeding_reason_other_{case_id}.
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase"

mappingId   ClinicalCaseICH
target      data:Case_{case_id} a resq:ClinicalCase; scdm:hasPart data:ClinicalProcedureSt_ICHNeuroSurgery_ich_treatment_hematoma_evacuation_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_ICHNeuroSurgery_ich_treatment_ventricular_drainage_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_ICHNeuroSurgery_ich_treatment_craniectomy_{case_id} ; scdm:hasPart data:ClinicalSituationSt_TIAClinicalSymptoms_tia_clinical_symptoms_{case_id} ; scdm:hasPart data:ObservationResultSt_TimeSymptomTIAlasts_tia_symptoms_duration_{case_id} . 
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase"


mappingId   ClinicalCaseSAH
target      data:Case_{case_id} a resq:ClinicalCase; scdm:hasPart data:ObservationResultSt_HuntHessScore_hunt_hess_score_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_SHIntervention_sah_treatment_coiling_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_SHIntervention_sah_treatment_clipping_{case_id} ; scdm:hasPart  data:ClinicalProcedureSt_SHIntervention_sah_treatment_drainage_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_SHIntervention_sah_treatment_craniectomy_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_NimodipineAdm_nimodipine_{case_id}.
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase"


mappingId   ClinicalCaseCVT
target      data:Case_{case_id} a resq:ClinicalCase; scdm:hasPart data:ClinicalProcedureSt_CVTTreatment_cvt_treatment_anticoagulation_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_CVTTreatment_cvt_treatment_thrombectomy_{case_id}  ; scdm:hasPart data:ClinicalProcedureSt_CVTTreatment_cvt_treatment_thrombolysis_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_CVTTreatment_cvt_treatment_neurosurgery_{case_id} ; scdm:hasPart data:ClinicalSituationSt_StrokeMIMICDiagnosis_stroke_mimics_diagnosis_{case_id}. 
source      SELECT "case_id" from "public"."strokehealthcaremodel_inpatientcase"


mappingId   ClinicalCasePostAcuteCareOne
target      data:Case_{case_id} a resq:ClinicalCase ; scdm:hasPart data:ClinicalProcedureSt_PostAcuteCare_post_acute_care_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_PostAcuteArtificalVentilation_patient_ventilated_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_PostAcuteCraniectomy_craniectomy_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_PostAcuteCarotidArterisImaging_carotid_arteries_imaging_{case_id} ; scdm:hasPart data:ClinicalSituationSt_PostAcuteCarotidStenosis_carotid_stenosis_{case_id} ; scdm:hasPart data:ObservationResultSt_PostAcuteCarotidStenosisLevel_carotid_stenosis_level_{case_id} ; scdm:hasPart data:ClinicalProcedureSt_PostAcuteCarotidEndardectomy_carotid_endarterectomy_{case_id} ; scdm:hasPart data:ObservationResultSt_PostAcuteCarotidStenosisLevel_carotid_endarterectomy_timing_{case_id} .
