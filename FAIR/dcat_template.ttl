<http://resqplus-resources/ontologies/resqplus-data#graph/batches/<branch>>
        rdf:type                dcat:Dataset ;
        dct:theme               "database" ;
        dct:dataset             "RES-Q+ CC" ;
        dct:title               "RES-Q+ ClinicalCases" ;
        dct:description         "Clinical case studies regarding stroke management across various hospital settings." ;
        dct:publisher           <RES-Q+> ;
        dct:accrualPeriodicity  <http://purl.org/cld/freq/irregular> ;
        foaf:homepage           <https://www.resqplus.eu> ;
        dcat:keyword            "stroke care", "clinical cases" ;
        dct:license             <https://creativecommons.org/licenses/by/> ;
        dct:rights              "" ;

<RES-Q+>
        rdf:type   foaf:Agent ;
        foaf:name  "RES-Q+" .

<http://resqplus-resources/ontologies/resqplus-data#graph/batches/<branch>> dcat:hasVersion http://resqplus-resources/ontologies/resqplus-data#graph/batches/<branch>/<version>>  . 
<http://resqplus-resources/ontologies/resqplus-data#graph/batches/<branch>/<version>> a dcat:Dataset  ; 
  dct:issued '<date>'^^xsd:datetime  ; 
  dct:creator         <RES-Q+> ; 
  dcat:version        "<version>" ; 
  dcat:mediaType <https://www.iana.org/assignments/media-types/text/turtle> .
